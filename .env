# ── RabbitMQ Connection ──
RABBITMQ_HOST=dlq-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Your DLQ Queue Names (comma separated) ──
DLQ_NAMES=orders.dlq,payments.dlq,notifications.dlq
DLQ_PATTERNS=.dlq,-dlq,.dead-letter

# ── Database ──
DB_NAME=dlqanalyzer
DB_USER=root
DB_PASSWORD=root

# ── Kafka (optional) ──
KAFKA_BOOTSTRAP=localhost:9092

# ── DLQ Analyzer Login ──
DLQ_ADMIN_USER=admin
DLQ_ADMIN_PASSWORD=admin123
DLQ_VIEWER_USER=viewer
DLQ_VIEWER_PASSWORD=viewer123

# ── Optional AI Error Explanation ──
ANTHROPIC_API_KEY=