# Copy this file to `.env` and fill in your own values.
# NEVER commit your real `.env` — it is gitignored.

# ── Application ──
APP_NAME=dlq-analyzer
APP_PORT=8081

# ── Database (MySQL) ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=dlqanalyzer
DB_USER=your_db_user
DB_PASSWORD=change_me

# ── RabbitMQ ──
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# ── Kafka (stubbed — not yet implemented) ──
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_GROUP_ID=dlq-analyzer

# ── Redis ──
REDIS_HOST=localhost
REDIS_PORT=6379

# ── DLQ Configuration ──
# Comma-separated DLQ names to monitor. Leave blank to auto-discover by pattern.
DLQ_NAMES=orders.dlq,payments.dlq,notifications.dlq
DLQ_PATTERNS=.dlq,-dlq,.dead-letter
DLQ_KAFKA_SUFFIX=.DLT
DLQ_POLLING_INTERVAL_MS=30000
DLQ_REPLAY_RATE_PER_MINUTE=100

# ── DLQ Analyzer Login ──
# Change these before any non-local deployment.
DLQ_ADMIN_USER=admin
DLQ_ADMIN_PASSWORD=change_me
DLQ_VIEWER_USER=viewer
DLQ_VIEWER_PASSWORD=change_me

# ── Optional: AI Error Explanation ──
# Provide an Anthropic API key to enable AI-generated explanations of failures.
ANTHROPIC_API_KEY=
