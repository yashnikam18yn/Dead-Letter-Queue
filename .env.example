# ──────────────────────────────────────────────────────────────
#  DLQ Analyzer — configuration
#  Copy to `.env` (next to docker-compose.yml) BEFORE the first
#  `docker compose up`. `.env` is gitignored — keep secrets out of git.
#
#  Defaults below run a self-contained DEMO (bundled RabbitMQ).
#  To monitor your OWN RabbitMQ, fill in the "USE YOUR OWN RABBITMQ"
#  block further down.
# ──────────────────────────────────────────────────────────────

# ── Dashboard login ────────────────────────────────────────────
# What you sign in to the UI with. ADMIN can replay/discard; VIEWER is read-only.
DLQ_ADMIN_USER=admin
DLQ_ADMIN_PASSWORD=change_me
DLQ_VIEWER_USER=viewer
DLQ_VIEWER_PASSWORD=change_me


# ══════════════════════════════════════════════════════════════
#  USE YOUR OWN RABBITMQ  (uncomment + edit to monitor your broker)
#  Leave commented to use the bundled demo broker.
# ══════════════════════════════════════════════════════════════
# host.docker.internal = "the machine Docker is running on".
# Use it when your RabbitMQ runs on your host (not in this compose).
#RABBITMQ_HOST=host.docker.internal
#RABBITMQ_PORT=5672
#RABBITMQ_USER=guest
#RABBITMQ_PASSWORD=guest
#RABBITMQ_MGMT_URL=http://host.docker.internal:15672
#
# After setting these you can stop the demo broker:
#   docker compose stop dlq-rabbitmq


# ── AI error assistant (optional) ──────────────────────────────
# NOT yet implemented in the backend — placeholder for a future feature.
#ANTHROPIC_API_KEY=


# ── Internal storage (optional — defaults are fine) ────────────
# The analyzer's own MySQL. You normally never touch these.
# NOTE: DB_PASSWORD is locked in on first boot; to change it later run
#       `docker compose down -v` (wipes stored data) then up again.
DB_NAME=dlqanalyzer
DB_USER=root
DB_PASSWORD=root


# ── DLQ discovery (optional) ───────────────────────────────────
# Queues whose names end with any of these are auto-discovered.
DLQ_PATTERNS=.dlq,-dlq,.dead-letter
# OR pin an explicit comma-separated list (overrides auto-discovery):
DLQ_NAMES=
# Poll frequency in ms. Lower to see results faster while testing.
DLQ_POLLING_INTERVAL_MS=30000
